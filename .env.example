# Safe local defaults.
# Do not put real credentials in this file.

APP_MODE=OBSERVER
TRADING_ENABLED=false
EXECUTE=false
LOG_LEVEL=INFO
ENV=local
API_HOST=0.0.0.0

# Local default. Railway sets PORT automatically; API_PORT wins if explicitly set.
API_PORT=8000
# PORT=

WORKER_POLL_SECONDS=1.0

DATABASE_URL=
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_STATEMENT_TIMEOUT_MS=5000

# Do not add Kalshi credentials until a later PR explicitly asks for them.
# KALSHI_API_KEY_ID=
# KALSHI_PRIVATE_KEY=
