# Safe local defaults.
# Do not put real credentials in this file.

APP_MODE=OBSERVER
TRADING_ENABLED=false
EXECUTE=false
LOG_LEVEL=INFO
ENV=local
API_HOST=0.0.0.0

# Local default. Railway sets PORT automatically; API_PORT wins if explicitly set.
API_PORT=8000
# PORT=

WORKER_POLL_SECONDS=1.0

DATABASE_URL=
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_STATEMENT_TIMEOUT_MS=5000

# Kalshi REST resolver configuration.
# Real Kalshi credentials belong only in Railway API/worker env, never Vercel.
# Keep APP_MODE=OBSERVER, TRADING_ENABLED=false, and EXECUTE=false.
KALSHI_API_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_ENV=prod
KALSHI_BTC15_SERIES_TICKER=KXBTC15M
KALSHI_REST_TIMEOUT_SECONDS=10
KALSHI_RESOLVER_PARSER_VERSION=btc15_resolver_v1
# KALSHI_API_KEY_ID=
# KALSHI_PRIVATE_KEY=
